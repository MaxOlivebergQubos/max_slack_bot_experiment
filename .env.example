# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-search-preview

# Bot config
BOT_TRIGGER=!gaston

# Debug logging (set to a channel name like #gaston-log or a channel ID like C1234567890)
# Leave empty to disable debug logging entirely.
SLACK_LOG_CHANNEL=#gaston-log
