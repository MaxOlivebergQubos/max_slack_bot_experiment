# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-search-preview

# Bot config
BOT_TRIGGER=!gaston

# Debug logging (must be a channel ID like C1234567890, not a channel name)
# Leave empty to disable debug logging entirely.
SLACK_LOG_CHANNEL=C1234567890
